# 이 파일을 .env 로 복사하고 값을 채우세요. (.env 는 깃에 올리지 않음)

# --- DB ---
APP_DB_URL=postgresql+psycopg://contest_helper:contest_helper@localhost:5432/contest_helper
# 공모전(contests) DB = Supabase Postgres (읽기 전용 소스).
# Supabase 대시보드 > Project Settings > Database > Connection string(URI) 에서 복사.
# 드라이버를 psycopg 로: 맨 앞을 postgresql+psycopg:// 로, 끝에 ?sslmode=require 추가.
# 직접 연결(항상 켜진 서버에 적합): host=db.<ref>.supabase.co, port=5432, db=postgres
COMPETITION_DB_URL=postgresql+psycopg://postgres:CHANGE_ME@db.YOURREF.supabase.co:5432/postgres?sslmode=require

# --- 큐 ---
REDIS_URL=redis://localhost:6379/0

# --- LLM (둘 중 한 경로) ---
# 개발 초기(AI Studio):
GEMINI_API_KEY=
# 클라우드(Vertex AI):
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_LOCATION=us-central1

# --- 구글 OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- 세션 ---
SESSION_SECRET=dev-secret-change-me

# --- 관측(보너스) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
